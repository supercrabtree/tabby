{
  "manifest_version": 2,
  "name": "Tabby",
  "version": "0.1.0",
  "description": "Tab tree with folders and ephemeral auto-expiring tabs",
  "sidebar_action": {
    "default_title": "",
    "default_panel": "index.html",
    "default_icon": "icons/tabby.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "icons": {
    "48": "icons/tabby.svg",
    "96": "icons/tabby.svg"
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "MacCtrl+T"
      },
      "description": "Toggle Tabby sidebar"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabby@example.com",
      "strict_min_version": "115.0"
    }
  }
}
